{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "moduleResolution": "node",
    "strict": true,
    "outDir": "./dist/script",
    "rootDir": "./script",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  },
  "include": ["script/**/*.ts"],
  "exclude": ["dist"]
}